# Server Configuration
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*

# Database
# Connect to Supabase via connection pooling with Supavisor.
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase Auth & Storage
SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
SUPABASE_SERVICE_KEY="your-supabase-service-role-key"

# AI Providers
OPENAI_API_KEY="your-openai-api-key"

# TEE (Trusted Execution Environment) Layer
# Must be exactly 32 bytes (64 hex characters) for AES-256-GCM
TEE_MASTER_SECRET="your-32-byte-hex-string-secret"
