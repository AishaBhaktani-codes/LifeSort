# Server Configuration
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*

# Database
# Connect to Supabase via connection pooling with Supavisor.
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase Auth & Storage
SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
SUPABASE_SERVICE_KEY="your-supabase-service-role-key"

# AI Providers
OPENAI_API_KEY="your-openai-api-key"

# TEE (Trusted Execution Environment) Layer
# Generated 32-byte hex string for AES-256-GCM
TEE_MASTER_SECRET="8b8d89e5a1b9b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7"
